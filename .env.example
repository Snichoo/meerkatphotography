# Resend API key (already set in Vercel). For local dev, copy this file to
# .env.local and fill in the value.
RESEND=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides for the contact form emails.
# CONTACT_FROM must use a domain you've verified in Resend. Until
# meerkatphotography.au is verified, leave this unset to use Resend's shared
# onboarding sender (onboarding@resend.dev).
# CONTACT_FROM="Meerkat Photography <hello@meerkatphotography.au>"

# Where enquiries are delivered. Defaults to the studio inbox in src/lib/content.ts.
# CONTACT_TO=nora@meerkatphotography.au

# Canonical site origin used for SEO (canonical URLs, Open Graph, sitemap,
# robots, structured data). Defaults to https://meerkatphotography.au. Only set
# this if the site is served from a different domain.
# NEXT_PUBLIC_SITE_URL=https://meerkatphotography.au
